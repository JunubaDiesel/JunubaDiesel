# Google Gemini (AI chat, compose-quote, admin insights)
GOOGLE_GENERATIVE_AI_API_KEY=

# Admin: Basic auth for /admin/* and admin APIs
ADMIN_PASSWORD=

# Optional: machine-to-machine sync header
SYNC_SECRET=

# Contact form (Resend). Without this, production returns 503 unless using WhatsApp fallback.
RESEND_API_KEY=
CONTACT_FROM_EMAIL=onboarding@resend.dev

# Delga video sync → Vercel Blob (required for production Admin persistence)
# Also stores inventory.json, resources.json, oem-guides.json in production
BLOB_READ_WRITE_TOKEN=

# Optional: Vercel CLI non-interactive deploy (vercel.com/account/tokens)
VERCEL_TOKEN=

# Optional: Upstash Redis for distributed rate limiting in production
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Delga YouTube sync script
DELGA_YOUTUBE_CHANNEL=@delga2000ca
SYNC_VIDEO_LIMIT=20
